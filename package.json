{
  "name": "jsgame",
  "version": "0.1.0",
  "description": "JSgame — D&D 5e online coop com Mestre IA. Mobile + desktop, DOM puro, sessão de 30min.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "groq-sdk": "^0.9.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sql.js": "^1.12.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/node": "^22.9.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
