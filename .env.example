# Provider do DM IA: gemini | groq | anthropic (auto-detect se vazio)
# Ordem auto: gemini > anthropic > groq
DM_PROVIDER=gemini

# === GEMINI (FREE — Google AI Studio, qualidade alta) ===
# gemini-2.0-flash: 1500 req/dia, 15 RPM, SEM auto-billing
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# === GROQ (FREE — Llama 3.3 70B, baixa latência, fallback) ===
# https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# === ANTHROPIC (PAGO, melhor qualidade narrativa) ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# === OLLAMA (local, free, qualidade menor) ===
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

SERVER_PORT=3001
